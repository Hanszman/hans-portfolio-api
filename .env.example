# Copy this file to ".env" and replace the placeholder values with your local credentials.
# NestJS loads this file at startup, and Prisma CLI commands read it directly too.

APP_NAME=Hans Portfolio API
NODE_ENV=development
PORT=3000
SWAGGER_PATH=swagger
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=1d

DATABASE_URL="postgresql://your-postgres-user:your-postgres-password@your-postgres-host:5432/hans-portfolio-db?schema=portfolio&sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://your-postgres-user:your-postgres-password@your-postgres-host:5432/hans-portfolio-db?schema=portfolio&sslmode=require&channel_binding=require"

PGHOST=your-postgres-host
PGDATABASE=hans-portfolio-db
PGUSER=your-postgres-user
PGPASSWORD=your-postgres-password
PGPORT=5432
PGSSLMODE=require
PGCHANNELBINDING=require
PGSCHEMA=portfolio

ADMIN_BOOTSTRAP_NAME=Victor Hanszman
ADMIN_BOOTSTRAP_EMAIL=victor@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!123
