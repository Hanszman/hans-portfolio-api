# Copy this file to ".env" and replace the placeholder values with your local database credentials.
# The API loads this file automatically during startup.

PGHOST=your-postgres-host
PGDATABASE=your-database-name
PGUSER=your-database-user
PGPASSWORD=your-database-password
PGPORT=5432
PGSSLMODE=Require
PGCHANNELBINDING=Require
